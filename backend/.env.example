# =============================================
# PLANT BOOK - Environment Variables
# Sao chép file này thành .env và điền thông tin
# =============================================

# Server
PORT=3000
NODE_ENV=production

# PostgreSQL (Supabase → Settings → Database → Connection string)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# JWT (đặt chuỗi bí mật ngẫu nhiên, ít nhất 32 ký tự)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=24h

# Supabase (Settings → API)
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_BUCKET=plant-media

# App
APP_URL=https://your-app.onrender.com

# Admin account (tạo lần đầu)
ADMIN_EMAIL=admin@tanbaocorp.vn
ADMIN_PASSWORD=Tanbao@123
